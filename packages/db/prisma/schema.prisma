// dogukanozgan.com — Prisma şeması (ortak veri katmanı)
// Kaynak: docs/04-veri-modeli.md. Yaklaşım B: ortak alanlar gerçek alan,
// ürüne özel değişken alanlar `payload` (JSON) içinde tutulur.
//
// VERİTABANI: MongoDB Atlas (Prisma `mongodb` provider) — K25 (kullanıcı kararı,
// Supabase/PostgreSQL'den geçiş). ID'ler ObjectId; yabancı anahtarlar @db.ObjectId.
//
// NOT: DB bağlantısı henüz yok (MongoDB Atlas bağlantısı bekleniyor) → şema cluster'a
// uygulanmadı. Sadece `prisma generate` ile client üretilir.
//
// ŞEMA UYGULAMA (gerçek MongoDB bağlanınca, packages/db içinde çalıştırılacak):
//   pnpm --filter @do/db db:push        # = prisma db push
// MongoDB'de SQL migration dosyaları YOKTUR (`prisma migrate` PostgreSQL'e özgüydü);
// şema doğrudan `db push` ile senkronlanır.
// Dosya depolama: Vercel Blob (bkz. src/storage.ts) — bucket/policy gerekmez.
//
// Aşama 2 NOTU: Teklif akışı + KVKK rıza kanıtı + dosya yükleme + silme/anonimleştirme
// ŞEMA DEĞİŞİKLİĞİ GEREKTİRMEDİ (mevcut QuoteRequest/Asset alanları yeterli).
//
// Aşama 3 NOTU (admin auth): User modeline `passwordHash` (bcrypt) alanı eklendi —
// docs/05 "Şifreler hash'lenir". Auth.js Credentials + JWT oturumu kullanılır;
// adapter (Account/Session tabloları) GEREKMEZ.
//
// Aşama 7 NOTU (docs/12 — İletişim/Bildirim/Poliçe/Mail): QuoteRequest'e poliçe
// yaşam döngüsü alanları (trackingCode/source/policy*), iki yeni model
// (ContactRequest, Notification) ve üç yeni enum (QuoteSource, ContactStatus,
// NotificationType) eklendi. Model/alan isimleri docs/12 §1 + docs/04 ile birebir.
//
// ⚠️ db push UYARISI: Bu şema CANLI MongoDB Atlas'a HENÜZ uygulanMADI. Şema
// değişikliklerini kullanıcı (Atlas erişimi olan) uygulayacak:
//     pnpm --filter @do/db db:push
// Agent bu komutu ÇALIŞTIRMAZ (canlı DB bağlantısı yok). Yalnızca `prisma generate`
// ile client güncellenir. Yeni `trackingCode @unique` ve poliçe alanları db push
// sonrası sorgulanabilir olur.

generator client {
  provider = "prisma-client-js"
  // "native" = yerel geliştirme; "rhel-openssl-3.0.x" = Vercel (Linux) çalışma zamanı.
  // Bu olmadan Vercel'de "could not locate the Query Engine" hatası alınır.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Gelen teklif talepleri
model QuoteRequest {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  product String // ürün slug: "trafik" | "saglik" | "bireysel-emeklilik" | "konut" ...
  locale  String @default("tr") // formun doldurulduğu dil

  // Durum-takip kodu (K30/docs/12): kısa (≈10), tahmin-edilemez (base32). Müşteri
  // web'de bu kodu girip teklif durumunu sorgular. @unique → benzersizlik garantisi.
  trackingCode String @unique

  // Talebin kaynağı (K32/docs/12): WEB = site formu, MANUAL = admin elle girişi.
  source QuoteSource @default(WEB)

  // Ortak iletişim alanları (sorgulanabilir olsun diye gerçek alan)
  fullName String
  phone    String
  email    String?

  // Ürüne özel tüm alanlar (TC, plaka, m², yaş, kronik hastalık vb.)
  payload Json

  // KVKK rıza kayıtları (kanıt için ZORUNLU — bkz. docs/06)
  consentKvkk      Boolean   @default(false)
  consentSensitive Boolean   @default(false) // sağlık verisi vb. için ayrı rıza
  consentAt        DateTime?
  consentIp        String?
  consentUserAgent String?

  // CRM alanları
  status QuoteStatus @default(YENI)
  notes  Note[]
  assets Asset[] // yüklenen fotoğraf/dosyalar (örn. trafikte ruhsat)

  // Poliçe yaşam döngüsü (K32/docs/12). status=POLICE_YAPILDI olunca doldurulur.
  policyStartDate DateTime?
  policyEndDate   DateTime?
  // Yüklenen poliçe belgesi referansı. Belge bir Asset (kind="police") olarak
  // saklanır; bu alan o Asset'in id'sini tutar (hızlı erişim için). docs/12 §1.
  policyAssetId   String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([product])
  @@index([status])
  @@index([createdAt])
  @@index([policyEndDate])
}

// Teklif/poliçe kaydının kaynağı (K32). MANUAL = web dışı (admin elle ekledi).
enum QuoteSource {
  WEB
  MANUAL
}

// CRM durum akışı
enum QuoteStatus {
  YENI // Yeni geldi
  ARANDI // İletişime geçildi
  TEKLIF_VERILDI // Teklif sunuldu
  POLICE_YAPILDI // Satışa dönüştü
  IPTAL // Vazgeçildi / ulaşılamadı
}

// Admin'in talebe eklediği notlar (CRM)
model Note {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  quote     QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   String       @db.ObjectId
  body      String
  createdAt DateTime     @default(now())
}

// Admin kullanıcılar (Auth.js)
//
// PIN KİLİT (docs/05 "Boşta Kilit / PIN"): Giriş oturumu açıkken, panel bir süre boşta
// kalınca tam ekran kilit overlay'i 4 haneli PIN ister (şifre tekrar sorulmaz). PIN
// bcrypt ile hash'lenir (pinHash); düz PIN ASLA saklanmaz. Kilit yalnız UI gate'tir —
// oturum JWT'si geçerli kalır, ama PIN doğrulaması her zaman SUNUCUDA yapılır.
model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  name         String?
  // Şifre HASH'i (bcrypt). docs/05 "Şifreler hash'lenir". Auth.js Credentials
  // provider bunu doğrular. Nullable: ileride OAuth/adapter kullanıcısı eklenirse
  // şifresiz hesap mümkün olsun (şimdilik tek credentials admin).
  passwordHash String?
  // 4 haneli boşta-kilit PIN'inin bcrypt HASH'i. null = PIN henüz oluşturulmadı
  // (ilk girişte kapatılamaz modal ile kurulur). Düz PIN saklanmaz/loglanmaz.
  pinHash      String?
  // Boşta kalınca kilitlenme süresi (dakika). 0 = kilit KAPALI. İzinli: 0/5/15/30/60.
  // docs/05 — süre ayarlardan değiştirilebilir veya kapatılabilir. Varsayılan 15 dk.
  lockTimeoutMinutes Int @default(15)
  // PIN'in en son ne zaman ayarlandığı/değiştirildiği (bilgi amaçlı, audit'e yardımcı).
  pinUpdatedAt DateTime?
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  // Auth.js JWT oturumu kullanılır (Aşama 3) → Account/Session tablosu GEREKMEZ.
  // İleride DB session/OAuth istenirse adapter + bu tablolar eklenir.
}

enum Role {
  ADMIN
}

// Yüklenen dosya/fotoğraflar (Vercel Blob referansı)
// Birincil kullanım: TRAFİK sigortasında müşteriden istenen ruhsat/araç fotoğrafları.
model Asset {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  path      String // Vercel Blob pathname (silme/okuma için kullanılır)
  url       String // Private Blob URL (access:"private"); token ile yalnız sunucudan okunur — docs/06 KVKK notu
  kind      String        @default("ruhsat") // "ruhsat" | "arac" | "belge" ...
  mimeType  String?
  sizeBytes Int?
  quote     QuoteRequest? @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   String?       @db.ObjectId // hangi teklife ait
  createdAt DateTime      @default(now())

  @@index([quoteId])
}

// Ziyaretçi iletişim talepleri (K31/docs/12). Web iletişim formu artık (WhatsApp
// yerine veya yanında) buraya kaydeder; admin'de "İletişim Talepleri" sayfasına düşer.
model ContactRequest {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  fullName String
  phone    String
  email    String?
  subject  String?
  message  String

  status ContactStatus @default(YENI)

  // KVKK rıza kanıtı (docs/06): iletişim formunda da aydınlatma + rıza zorunlu.
  consentKvkk      Boolean   @default(false)
  consentAt        DateTime?
  consentIp        String?
  consentUserAgent String?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// İletişim talebi CRM durum akışı (K31).
enum ContactStatus {
  YENI // Yeni geldi
  OKUNDU // Görüldü
  YANITLANDI // Yanıt verildi
  KAPANDI // Kapatıldı
}

// Admin içi bildirimler (K29/docs/12). Admin header'daki çan okunmamışları gösterir.
// Kaynaklar: yeni teklif (TEKLIF), yeni iletişim talebi (ILETISIM), yaklaşan/biten
// poliçe (POLICE_BITIS). Doğukan'a otomatik MAIL gönderilmez; yalnız panel içi.
model Notification {
  id    String           @id @default(auto()) @map("_id") @db.ObjectId
  type  NotificationType
  title String
  body  String?
  // İlgili kaydın id'si (örn. QuoteRequest.id / ContactRequest.id). Tıklayınca
  // admin ilgili kayda gider. Tip bazlı; bu yüzden FK ilişkisi kurulmaz (esnek).
  relatedId String? @db.ObjectId
  read      Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}

// Bildirim türü (K29).
enum NotificationType {
  TEKLIF // Yeni teklif talebi
  ILETISIM // Yeni iletişim talebi
  POLICE_BITIS // Yaklaşan/biten poliçe
}

// İki adımlı admin girişi (2FA) — e-posta OTP doğrulama kodu. docs/05 (Kimlik Doğrulama).
//
// AKIŞ (apps/admin login): şifre doğrulandıktan SONRA 6 haneli rastgele kod üretilir,
// HASH'lenip (sha256 + AUTH_SECRET) buraya yazılır, e-postayla gönderilir. Adım 2'de
// kullanıcı kodu girer; hash eşleşir + süre (10dk) geçmemiş + deneme < 5 ise oturum açılır.
// Kod ASLA düz metin saklanmaz; başarılı/iptal sonrası satır SİLİNİR.
//
// Tek-admin senaryosunda e-posta başına en çok bir aktif kod tutulur (upsert);
// `email @unique` bunu garanti eder. `expiresAt` index ile süresi geçenler sorgulanır
// (TTL otomatik silme isteğe bağlı; RateLimit ile aynı not — Atlas'ta el ile kurulabilir).
//
// ⚠️ db push UYARISI: Bu yeni koleksiyon CANLI MongoDB Atlas'a HENÜZ uygulanMADI.
// Kullanıcı uygular: `pnpm --filter @do/db db:push` (yeni `LoginCode` koleksiyonu + index).
// Agent yalnız `prisma generate` ile client'ı günceller.
model LoginCode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique // normalize (lowercase) admin e-postası — aktif kod sahibi
  codeHash  String // sha256(code + AUTH_SECRET) — düz kod ASLA saklanmaz
  expiresAt DateTime // kodun geçerlilik bitişi (üretim + 10dk)
  attempts  Int      @default(0) // yanlış deneme sayacı; >=5 olunca kod geçersiz
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// Dağıtık (kalıcı) rate-limit sayacı — docs/13 §Y2.
// Mevcut MongoDB üzerinde tutulur (Upstash/Redis gibi EK SERVİS KURULMAZ — kullanıcı
// kararı: non-teknik, ek altyapı istenmez). In-memory limiter serverless'te her
// instance'ta ayrı saydığı için gerçek koruma sağlamıyordu (D2); bu model ile sayaç
// tüm instance'larda paylaşılır.
//
// key örnekleri: "login:1.2.3.4:user@example.com" | "quote:1.2.3.4" | "loc:1.2.3.4".
// Limit mantığı `expiresAt` sorgusuyla pencereyi kontrol eder (src/rate-limit.ts).
//
// ⚠️ `expiresAt` üzerinde standart index `prisma db push` ile oluşur. NOT: Prisma
// MongoDB provider'ı henüz TTL (`expireAfterSeconds`) index'ini şemadan ÜRETMEZ —
// gerçek otomatik silme için Atlas'ta tek seferlik el ile TTL index kurulur:
//   db.RateLimit.createIndex({ expiresAt: 1 }, { expireAfterSeconds: 0 })
// (docs/13 §Y2'de adımlar var.) TTL kurulana kadar süresi dolmuş kayıtlar OTOMATİK
// SİLİNMEZ; ancak limit mantığı her zaman `expiresAt`'i sorguladığı için DOĞRU çalışır
// (yalnızca eski satırlar birikir → zararsız, periyodik manuel temizlik yeterli).
model RateLimit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique // "kapsam:ip[:kimlik]" — atomik sayaç anahtarı
  count       Int      @default(0)
  windowStart DateTime // mevcut pencerenin başlangıcı
  expiresAt   DateTime // pencere bitişi; süre dolunca pencere sıfırlanır / TTL ile silinir

  @@index([expiresAt])
}
