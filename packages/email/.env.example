# packages/email — Resend / e-posta ortam değişkenleri (ÖRNEK) — K28.
# Gerçek değerleri `.env` (commit EDİLMEZ) içine koyun.
# Kaynak: docs/12 §5 "Ortam Değişkenleri" + K28.
#
# Bu paket env-flag'lidir: RESEND_API_KEY yoksa gönderim ZARİFÇE atlanır
# (akış kırılmaz — bkz. isEmailConfigured()). Anahtar YALNIZCA sunucuda kullanılır.

# Resend API anahtarı. https://resend.com/api-keys
# 🔧 Sonra netleşecek: anahtar + dogukanozgan.com alan doğrulaması Doğukan'da.
RESEND_API_KEY=

# Gönderen adresi. Alan (dogukanozgan.com) Resend'de doğrulanmış olmalı.
EMAIL_FROM="Doğukan Özgan <teklif@dogukanozgan.com>"

# Durum-sorgu linkleri için site kökü (web app'te zaten tanımlı). E-posta
# fonksiyonlarına tam URL parametre olarak geçer; bu yalnız referans amaçlıdır.
# NEXT_PUBLIC_SITE_URL=https://dogukanozgan.com
