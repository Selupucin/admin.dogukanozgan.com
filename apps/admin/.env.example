# apps/admin — admin.dogukanozgan.com ortam değişkenleri (ÖRNEK).
# Gerçek değerleri Vercel proje ayarlarına / yerel `.env.local` içine girin.
# Kaynak: docs/01 "Ortam Değişkenleri".

# --- Veritabanı (apps/web ve packages/db ile AYNI MongoDB Atlas) — K25 ---
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dogukanozgan?retryWrites=true&w=majority"

# --- Vercel Blob (ruhsat/araç fotoğrafları — admin doğrudan URL ile görüntüler) — K25 ---
# apps/web ile AYNI Blob store token'ı.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_<token>"

# --- Auth.js (admin girişi — Aşama 3) ---
# AUTH_SECRET oturum çerezini şifreler. Üret: `openssl rand -base64 32`
AUTH_SECRET="<openssl rand -base64 32 ile üret>"

# İlk admin kullanıcı oluşturmak için (packages/db seed:admin scripti okur):
#   ADMIN_EMAIL="dogukan@dogukanozgan.com" ADMIN_PASSWORD="..." \
#     pnpm --filter @do/db seed:admin
ADMIN_EMAIL="admin@dogukanozgan.com"
# ADMIN_PASSWORD ve ADMIN_NAME yalnızca seed:admin çalıştırılırken gerekir.
# ADMIN_PASSWORD="en az 8 karakter güçlü şifre"
# ADMIN_NAME="Doğukan Özgan"
