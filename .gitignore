# ---------------------------------------------------------------------------
# dogukanozgan.com — kök .gitignore (monorepo)
# Kapsam: Node/pnpm, Next.js, Turborepo, Prisma, Supabase, TypeScript, Husky,
# editor/OS artefaktları, .env*. Her app/package altındaki ek ignore'lar
# gerekirse kendi dizinlerinde olur.
# ---------------------------------------------------------------------------

# --- Bağımlılıklar ---
node_modules/
.pnp
.pnp.*
.yarn/install-state.gz

# --- Build çıktıları ---
.next/
out/
dist/
build/
.vercel/
.turbo/

# --- Test / coverage ---
coverage/
*.lcov
.nyc_output/

# --- Loglar ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Ortam değişkenleri (KVKK/güvenlik: HİÇBİR .env commit edilmez) ---
.env
.env.*
!.env.example
!.env.*.example

# --- Prisma ---
# schema.prisma commit edilir; üretilmiş client ve geçici dosyalar değil
**/prisma/.env
**/prisma/generated/
**/prisma/migrations/dev.db*

# --- MongoDB / Prisma yerel araçları (K25; Supabase bırakıldı) ---
.supabase/
*.mongodb

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Husky kurulum çıktısı (kaynak .husky/ commit edilir) ---
.husky/_/

# --- Editörler ---
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# --- İşletim sistemi ---
.DS_Store
Thumbs.db
desktop.ini

# --- Geçici dosyalar ---
*.tmp
*.bak
.cache/
